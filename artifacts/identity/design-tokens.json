{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Studio Ceramic E2E — Atelierul ca pagină vie",
    "version": "1.0.0",
    "status": "proposed",
    "source": "brief, production brief, artifacts/research/market-research.md și judecăți de design trasabile în visual-direction.md",
    "implementationNote": "Tokenii sunt semantici. Constructorul îi mapează în variabilele :root din src/app/globals.css; nu se introduc culori direct în componente."
  },
  "color": {
    "primitive": {
      "cream50": { "$type": "color", "$value": "#FCF8F2" },
      "cream100": { "$type": "color", "$value": "#F7F0E5" },
      "cream200": { "$type": "color", "$value": "#EADFD1" },
      "ink900": { "$type": "color", "$value": "#2C2520" },
      "ink700": { "$type": "color", "$value": "#4B433C" },
      "ink600": { "$type": "color", "$value": "#665D55" },
      "terracotta700": { "$type": "color", "$value": "#713523" },
      "terracotta600": { "$type": "color", "$value": "#91452F" },
      "terracotta200": { "$type": "color", "$value": "#E8C9B8" },
      "sage700": { "$type": "color", "$value": "#465044" },
      "sage200": { "$type": "color", "$value": "#DCE1D2" },
      "white": { "$type": "color", "$value": "#FFFFFF" },
      "error700": { "$type": "color", "$value": "#8B2E2E" }
    },
    "semantic": {
      "background": { "$type": "color", "$value": "{color.primitive.cream100}" },
      "surface": { "$type": "color", "$value": "{color.primitive.cream50}" },
      "surfaceMuted": { "$type": "color", "$value": "{color.primitive.sage200}" },
      "surfaceWarm": { "$type": "color", "$value": "{color.primitive.terracotta200}" },
      "foreground": { "$type": "color", "$value": "{color.primitive.ink900}" },
      "foregroundMuted": { "$type": "color", "$value": "{color.primitive.ink600}" },
      "primary": { "$type": "color", "$value": "{color.primitive.terracotta600}" },
      "primaryHover": { "$type": "color", "$value": "{color.primitive.terracotta700}" },
      "onPrimary": { "$type": "color", "$value": "{color.primitive.cream100}" },
      "secondary": { "$type": "color", "$value": "{color.primitive.sage700}" },
      "onSecondary": { "$type": "color", "$value": "{color.primitive.white}" },
      "border": { "$type": "color", "$value": "{color.primitive.cream200}" },
      "borderStrong": { "$type": "color", "$value": "{color.primitive.ink700}" },
      "focusRing": { "$type": "color", "$value": "{color.primitive.ink900}" },
      "link": { "$type": "color", "$value": "{color.primitive.terracotta700}" },
      "error": { "$type": "color", "$value": "{color.primitive.error700}" }
    }
  },
  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": ["Fraunces", "Georgia", "Times New Roman", "serif"] },
      "body": { "$type": "fontFamily", "$value": ["Manrope", "Arial", "Helvetica", "sans-serif"] }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 }
    },
    "size": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.125rem" },
      "xl": { "$type": "dimension", "$value": "1.375rem" },
      "2xl": { "$type": "dimension", "$value": "1.75rem" },
      "3xl": { "$type": "dimension", "$value": "2.25rem" },
      "4xl": { "$type": "dimension", "$value": "3rem" },
      "5xl": { "$type": "dimension", "$value": "4rem" },
      "6xl": { "$type": "dimension", "$value": "5rem" }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.05 },
      "heading": { "$type": "number", "$value": 1.15 },
      "body": { "$type": "number", "$value": 1.65 },
      "ui": { "$type": "number", "$value": 1.4 }
    },
    "letterSpacing": {
      "tight": { "$type": "dimension", "$value": "-0.02em" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "label": { "$type": "dimension", "$value": "0.04em" }
    },
    "role": {
      "display": { "$type": "typography", "$value": { "fontFamily": "{font.family.display}", "fontSize": "{font.size.5xl}", "fontWeight": "{font.weight.medium}", "letterSpacing": "{font.letterSpacing.tight}", "lineHeight": "{font.lineHeight.tight}" } },
      "heading": { "$type": "typography", "$value": { "fontFamily": "{font.family.display}", "fontSize": "{font.size.3xl}", "fontWeight": "{font.weight.medium}", "letterSpacing": "{font.letterSpacing.tight}", "lineHeight": "{font.lineHeight.heading}" } },
      "body": { "$type": "typography", "$value": { "fontFamily": "{font.family.body}", "fontSize": "{font.size.base}", "fontWeight": "{font.weight.regular}", "letterSpacing": "{font.letterSpacing.normal}", "lineHeight": "{font.lineHeight.body}" } },
      "ui": { "$type": "typography", "$value": { "fontFamily": "{font.family.body}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.semibold}", "letterSpacing": "{font.letterSpacing.normal}", "lineHeight": "{font.lineHeight.ui}" } }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "6": { "$type": "dimension", "$value": "1.5rem" },
    "8": { "$type": "dimension", "$value": "2rem" },
    "12": { "$type": "dimension", "$value": "3rem" },
    "16": { "$type": "dimension", "$value": "4rem" },
    "20": { "$type": "dimension", "$value": "5rem" },
    "24": { "$type": "dimension", "$value": "6rem" },
    "32": { "$type": "dimension", "$value": "8rem" },
    "36": { "$type": "dimension", "$value": "9rem" }
  },
  "size": {
    "contentMax": { "$type": "dimension", "$value": "75rem" },
    "textMeasure": { "$type": "dimension", "$value": "42.5rem" },
    "touchTargetMin": { "$type": "dimension", "$value": "2.75rem" },
    "controlHeight": { "$type": "dimension", "$value": "3rem" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "control": { "$type": "dimension", "$value": "0.5rem" },
    "base": { "$type": "dimension", "$value": "0.625rem" },
    "card": { "$type": "dimension", "$value": "0.75rem" },
    "image": { "$type": "dimension", "$value": "1rem" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "border": {
    "width": {
      "default": { "$type": "dimension", "$value": "1px" },
      "focus": { "$type": "dimension", "$value": "2px" }
    }
  },
  "shadow": {
    "raised": { "$type": "shadow", "$value": { "color": "#2C252014", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" } }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "160ms" },
      "base": { "$type": "duration", "$value": "240ms" },
      "slow": { "$type": "duration", "$value": "320ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] }
    },
    "distance": {
      "enter": { "$type": "dimension", "$value": "0.75rem" }
    }
  },
  "layout": {
    "gutterMobile": { "$type": "dimension", "$value": "1rem" },
    "gutterTablet": { "$type": "dimension", "$value": "2rem" },
    "gutterDesktop": { "$type": "dimension", "$value": "3rem" },
    "sectionBlockMobile": { "$type": "dimension", "$value": "4rem" },
    "sectionBlockDesktop": { "$type": "dimension", "$value": "7.5rem" },
    "gridColumns": { "$type": "number", "$value": 12 },
    "gridGap": { "$type": "dimension", "$value": "1.5rem" }
  },
  "imagery": {
    "ratioPortrait": { "$type": "string", "$value": "4 / 5" },
    "ratioLandscape": { "$type": "string", "$value": "3 / 2" },
    "ratioHero": { "$type": "string", "$value": "16 / 10" },
    "textureOpacityMax": { "$type": "number", "$value": 0.04 }
  }
}
