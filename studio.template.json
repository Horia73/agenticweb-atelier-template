{
  "framework": "nextjs-app-router",
  "paths": {
    "appRoot": "src/app",
    "publicAssets": "public",
    "tokenAdapter": "src/app/globals.css",
    "contentAdapter": "src/content.ts"
  },
  "ui": {
    "primitiveFoundation": "shadcn",
    "designMode": "hybrid",
    "config": "components.json",
    "components": "src/components/ui",
    "skill": ".agents/skills/shadcn/SKILL.md",
    "enforcementScript": "check:ui"
  },
  "experience": {
    "catalogVersion": "3.1.0",
    "registry": "registry.json",
    "catalog": "experience.catalog.json",
    "grammar": "creative-grammar.json",
    "components": "src/components/experience",
    "skill": ".agents/skills/experience-primitives/SKILL.md",
    "responsiveContract": "docs/experience/responsive-contract.md",
    "labRoute": "/experience-lab",
    "labEnv": "EXPERIENCE_LAB=1"
  },
  "scripts": {
    "dev": "dev:preview",
    "build": "build",
    "typecheck": "typecheck",
    "lint": "lint",
    "test": null,
    "accessibility": null,
    "performance": null
  },
  "preview": {
    "distDirEnv": "NEXT_DIST_DIR"
  },
  "agenticwebApps": {
    "environment": ["NEXT_PUBLIC_AWOS_SITE_KEY", "NEXT_PUBLIC_AWOS_URL"],
    "components": {
      "chatbot": "src/components/agenticweb/chatbot.tsx",
      "booking": "src/components/agenticweb/booking-widget.tsx",
      "restaurantMenu": "src/components/agenticweb/restaurant-menu.tsx",
      "hotelBooking": "src/components/agenticweb/hotel-booking.tsx"
    }
  }
}
